# Sanity CMS — necessário para o /studio e para o conteúdo dinâmico.
# Sem estas vars o site cai gracefully para os dados estáticos em lib/packs.ts
# e lib/servicos.ts (o site não parte).
#
# Setup:
#   1. Cria projecto em https://www.sanity.io/manage (Google login)
#   2. Copia o projectId que aparece na dashboard
#   3. Cria um dataset chamado "production" (ou usa o default)
#   4. Adiciona o teu email + o do cliente como "Editor" em Members
#   5. Em API → Tokens, cria um token com permissões "Editor" → SANITY_API_WRITE_TOKEN
#   6. Copia este ficheiro para .env.local e preenche
#   7. Corre: pnpm seed (popula com os dados actuais)
#
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Apenas necessário para o seed script (pnpm seed). Em produção (Vercel) só
# precisas das NEXT_PUBLIC_* acima.
SANITY_API_WRITE_TOKEN=

# Resend (envios de email do /orcamento) — já existente
RESEND_API_KEY=

# Plausible analytics (opcional, sem cookies)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
